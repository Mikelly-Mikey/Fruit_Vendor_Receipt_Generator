# Environment variables for Fresh Fruits Market
# Copy this file to .env and update with your values

# MongoDB Configuration
MONGO_URI=mongodb://admin:admin123@localhost:27017/fruit_vendor_db?authSource=admin
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=secure_password_change_me
MONGO_INITDB_DATABASE=fruit_vendor_db

# Application Configuration
VAT_RATE=0.16
VAT_INCLUSIVE=true
MONGO_TIMEOUT_MS=5000

# Security
# Set to true in production to disable debug features
PRODUCTION=false

# Logging
LOG_LEVEL=INFO
